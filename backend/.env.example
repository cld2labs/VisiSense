# =================================================================
# VisiSense - CatalogIQ Backend Configuration
# =================================================================

# =================================================================
# LLM Provider Configuration (REQUIRED)
# =================================================================
# Supported providers: openai, groq, ollama, openrouter, or custom
LLM_PROVIDER=openai

# API key for the selected provider
# OpenAI: Get from https://platform.openai.com/api-keys
# Groq: Get from https://console.groq.com/keys
# Ollama: Leave empty (no key needed)
# OpenRouter: Get from https://openrouter.ai/keys
LLM_API_KEY=your_api_key_here

# Base URL for the LLM API
# OpenAI: https://api.openai.com/v1
# Groq: https://api.groq.com/openai/v1
# Ollama: http://localhost:11434/v1
# OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name to use
# OpenAI: gpt-4o, gpt-4-turbo, gpt-4o-mini
# Groq: llama-3.2-90b-vision-preview, llama-3.2-11b-vision-preview
# Ollama: qwen2.5-vl:7b, llama3.2-vision:11b, bakllava
# OpenRouter: anthropic/claude-3-haiku, google/gemini-pro-vision
LLM_MODEL=gpt-4o

# =================================================================
# Generation Parameters
# =================================================================
# Model temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.3

# Maximum tokens per response
MAX_TOKENS=2048

# Number of retry attempts on API failures
MAX_RETRIES=3

# Request timeout in seconds
REQUEST_TIMEOUT=120

# =================================================================
# File Upload Limits
# =================================================================
# Maximum image file size in MB
MAX_IMAGE_SIZE_MB=10

# Maximum number of images per analysis
MAX_IMAGES_PER_REQUEST=5

# =================================================================
# Session Management
# =================================================================
# Session expiration time in minutes
CHAT_SESSION_TTL_MINUTES=30

# Maximum number of chat history turns to maintain
CHAT_MAX_HISTORY_TURNS=10

# =================================================================
# Server Configuration
# =================================================================
# Backend service port
SERVICE_PORT=8000

# Environment mode (development or production)
PYTHON_ENV=development

# =================================================================
# SSL/TLS Configuration
# =================================================================
# SSL certificate verification for HTTPS requests
# Set to 'false' for environments with self-signed certificates
# (e.g., Xeon machines without proper SSL certificates)
# Set to 'true' for production with valid certificates
# Default: true
VERIFY_SSL=true
