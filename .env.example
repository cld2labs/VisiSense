# =================================================================
# VisiSense - CatalogIQ Root Configuration
# =================================================================
# This file is for reference only - copy to backend/.env for use
# =================================================================

# =================================================================
# LLM Provider Configuration (REQUIRED)
# =================================================================
# Supported providers: openai, groq, ollama, openrouter, or custom
LLM_PROVIDER=openai

# API key for the selected provider
LLM_API_KEY=your_api_key_here

# Base URL for the LLM API
LLM_BASE_URL=https://api.openai.com/v1

# Model name to use
LLM_MODEL=gpt-4o

# =================================================================
# Example Configurations by Provider
# =================================================================

# OpenAI (Recommended for Production)
# Get API key: https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Groq (Fast & Free Tier)
# Get API key: https://console.groq.com/keys
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.2-90b-vision-preview

# Ollama (Local & Private)
# Install: https://ollama.com, then: ollama pull qwen2.5-vl:7b
# LLM_PROVIDER=ollama
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5-vl:7b

# OpenRouter (Multi-Model Access)
# Get API key: https://openrouter.ai/keys
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-3-haiku

# =================================================================
# Generation Parameters
# =================================================================
TEMPERATURE=0.3
MAX_TOKENS=2048
MAX_RETRIES=3
REQUEST_TIMEOUT=120

# =================================================================
# File Upload Limits
# =================================================================
MAX_IMAGE_SIZE_MB=10
MAX_IMAGES_PER_REQUEST=5

# =================================================================
# Session Management
# =================================================================
CHAT_SESSION_TTL_MINUTES=30
CHAT_MAX_HISTORY_TURNS=10

# =================================================================
# Server Configuration
# =================================================================
SERVICE_PORT=8000
PYTHON_ENV=development
